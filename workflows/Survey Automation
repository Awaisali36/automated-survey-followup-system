      "parameters": {
        "jsCode": "// Get attendees from the deduplicated list\nconst attendees = $('Remove Duplicate Emails').all();\n\n// Get Typeform responses - handle the nested structure\nconst typeformNode = $('Fetch Recent Typeform Responses').first().json;\n\n// The Typeform API returns { items: [...], total_items: X, page_count: Y }\n// Handle both direct items array and nested structure\nlet responses = [];\nif (Array.isArray(typeformNode)) {\n  // If it's an array, it might be wrapped\n  responses = typeformNode;\n} else if (typeformNode.items) {\n  // Standard Typeform API response\n  responses = typeformNode.items;\n} else if (typeformNode.body && typeformNode.body.items) {\n  // If wrapped in body (some HTTP node configs)\n  responses = typeformNode.body.items;\n} else {\n  // Fallback - try to use as-is\n  responses = typeformNode;\n}\n\nconsole.log(`Total Typeform responses found: ${responses.length}`);\n\n// 1. Calculate the 48-hour cutoff time\nconst now = new Date();\nconst cutoffTime = new Date(now.getTime() - (48 * 60 * 60 * 1000)); // 48 hours ago\n\n// 2. Build a Set of emails AND names who submitted recently\nconst recentRespondentEmails = new Set();\nconst recentRespondentNames = new Set();\n\n// Specific Field IDs from your Typeform JSON\nconst FIRST_NAME_FIELD_ID = \"VGppOy8XqOlc\";\nconst LAST_NAME_FIELD_ID = \"mV9ICWq5ZoSj\";\nconst EMAIL_FIELD_ID = \"4Ghw0zu2jL9C\";\n\nfor (const response of responses) {\n  // Check if submission is within last 48 hours\n  const submittedAt = new Date(response.submitted_at);\n  \n  if (submittedAt > cutoffTime) {\n    const answers = response.answers || [];\n    \n    // Find the specific answer objects by ID\n    const firstNameAnswer = answers.find(a => a.field && a.field.id === FIRST_NAME_FIELD_ID);\n    const lastNameAnswer = answers.find(a => a.field && a.field.id === LAST_NAME_FIELD_ID);\n    const emailAnswer = answers.find(a => a.field && a.field.id === EMAIL_FIELD_ID);\n\n    const firstName = firstNameAnswer ? (firstNameAnswer.text || \"\") : \"\";\n    const lastName = lastNameAnswer ? (lastNameAnswer.text || \"\") : \"\";\n    const email = emailAnswer ? (emailAnswer.email || \"\") : \"\";\n\n    // Add email to set (more reliable than name matching)\n    if (email) {\n      recentRespondentEmails.add(email.toLowerCase().trim());\n    }\n\n    // Also track by name as backup\n    const fullName = `${firstName} ${lastName}`.toLowerCase().trim().replace(/\\s+/g, ' ');\n    if (fullName.length > 1) {\n      recentRespondentNames.add(fullName);\n    }\n    \n    console.log(`Recent respondent: ${fullName} (${email}) - submitted ${submittedAt.toISOString()}`);\n  }\n}\n\nconsole.log(`Found ${recentRespondentEmails.size} email(s) and ${recentRespondentNames.size} name(s) in the last 48 hours.`);\n\n// 3. Filter out attendees who exist in either the email OR name exclusion list\nconst eligibleAttendees = attendees.filter(attendee => {\n  const attendeeEmail = (attendee.json.email || \"\").toLowerCase().trim();\n  const attendeeName = (attendee.json.name || \"\").toLowerCase().trim().replace(/\\s+/g, ' ');\n  \n  // Check both email and name\n  const emailExcluded = recentRespondentEmails.has(attendeeEmail);\n  const nameExcluded = recentRespondentNames.has(attendeeName);\n  \n  const isExcluded = emailExcluded || nameExcluded;\n  \n  if (isExcluded) {\n    console.log(`Excluding: ${attendeeName} (${attendeeEmail}) - Already submitted in last 48h`);\n  }\n  \n  return !isExcluded;\n});\n\nconsole.log(`${eligibleAttendees.length} eligible attendees after 48h exclusion`);\n\n// If list is empty, return a dummy item so the flow reaches the 'If' node\nif (eligibleAttendees.length === 0) {\n  return [\n    {\n      json: {\n        email: null, \n        name: \"No Data\"\n      }\n    }\n  ];\n}\n\nreturn eligibleAttendees;"
