      "parameters": {
        "jsCode": "// Extract event info from filename\nconst filename = $('Download CSV').first().json.name || 'Event';\nconst eventType = filename.toLowerCase().includes('otr') ? 'Off-the-Record' : 'ChatWalrus';\n\n// Clean event title from filename (remove date, extension)\nlet eventTitle = filename\n  .replace(/\\.(csv|xlsx)$/i, '')\n  .replace(/\\d{4}[-_]\\d{2}[-_]\\d{2}/g, '')\n  .replace(/[-_]/g, ' ')\n  .trim();\n\nif (!eventTitle) {\n  eventTitle = `${eventType} Session`;\n}\n\n// Get all items from CSV\nconst items = $input.all();\n\n// Return attendee data with event context\nreturn items.map(item => {\n  // Handle common CSV column names for email\n  const email = item.json.email || \n                item.json.Email || \n                item.json['Email Address'] || \n                item.json['email_address'] ||\n                item.json['User Email'] ||\n                '';\n  \n  // Handle common CSV column names for name\n  const name = item.json.name || \n               item.json.Name || \n               item.json['Full Name'] || \n               item.json['First Name'] ||\n               item.json['Name (original name)'] ||\n               '';\n  \n  // Extract first name\n  const firstName = name.split(' ')[0] || '';\n  \n  return {\n    json: {\n      email: email.toLowerCase().trim(),\n      name: name,\n      firstName: firstName,\n      eventTitle: eventTitle,\n      eventType: eventType,\n      eventDate: new Date().toISOString().split('T')[0],\n      processedAt: new Date().toISOString()\n    }\n  };\n}).filter(item => item.json.email && item.json.email.includes('@'));"
      },
