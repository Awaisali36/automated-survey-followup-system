      "parameters": {
        "jsCode": "// Get tracked emails from sheet\nconst trackedEmails = $('Read Email Tracking').all();\n\n// Get Typeform responses to check who completed\nconst typeformNode = $('Fetch Typeform (Followup)').first().json;\n\n// Handle nested Typeform response structure\nlet responses = [];\nif (Array.isArray(typeformNode)) {\n  responses = typeformNode;\n} else if (typeformNode.items) {\n  responses = typeformNode.items;\n} else if (typeformNode.body && typeformNode.body.items) {\n  responses = typeformNode.body.items;\n} else {\n  responses = typeformNode;\n}\n\nconsole.log(`Total Typeform responses found: ${responses.length}`);\n\nconst now = new Date();\nconst twentyFourHoursAgo = new Date(now.getTime() - (24 * 60 * 60 * 1000));\nconst fortyEightHoursAgo = new Date(now.getTime() - (48 * 60 * 60 * 1000));\n\n// Build set of recent respondents (48h) - by BOTH email and name\nconst FIRST_NAME_FIELD_ID = \"VGppOy8XqOlc\";\nconst LAST_NAME_FIELD_ID = \"mV9ICWq5ZoSj\";\nconst EMAIL_FIELD_ID = \"4Ghw0zu2jL9C\";\n\nconst recentRespondentEmails = new Set();\nconst recentRespondentNames = new Set();\n\nfor (const response of responses) {\n  const submittedAt = new Date(response.submitted_at);\n  if (submittedAt > fortyEightHoursAgo) {\n    const answers = response.answers || [];\n    \n    // Safe field access with null checks\n    const firstNameAnswer = answers.find(a => a.field && a.field.id === FIRST_NAME_FIELD_ID);\n    const lastNameAnswer = answers.find(a => a.field && a.field.id === LAST_NAME_FIELD_ID);\n    const emailAnswer = answers.find(a => a.field && a.field.id === EMAIL_FIELD_ID);\n    \n    const firstName = firstNameAnswer ? (firstNameAnswer.text || \"\") : \"\";\n    const lastName = lastNameAnswer ? (lastNameAnswer.text || \"\") : \"\";\n    const email = emailAnswer ? (emailAnswer.email || \"\") : \"\";\n    \n    // Track by email (more reliable)\n    if (email) {\n      recentRespondentEmails.add(email.toLowerCase().trim());\n    }\n    \n    // Also track by name as backup\n    const fullName = `${firstName} ${lastName}`.toLowerCase().trim().replace(/\\s+/g, ' ');\n    if (fullName.length > 1) {\n      recentRespondentNames.add(fullName);\n    }\n  }\n}\n\nconsole.log(`Found ${recentRespondentEmails.size} email(s) and ${recentRespondentNames.size} name(s) who responded in last 48h`);\n\n// Filter for emails that:\n// 1. Were sent initial email more than 24h ago\n// 2. Haven't received a reminder yet\n// 3. Haven't completed the survey (check against Typeform)\nconst needsReminder = trackedEmails.filter(item => {\n  const email = item.json.Email || item.json.email || '';\n  const name = item.json.Name || item.json.name || '';\n  const reminderSent = item.json['Reminder Sent'] || item.json.reminderSent;\n  const initialSentAt = item.json['Initial Sent At'] || item.json.initialSentAt;\n  \n  // Skip if no email\n  if (!email) return false;\n  \n  // Skip if reminder already sent\n  if (reminderSent === 'Yes' || reminderSent === 'yes' || reminderSent === true) return false;\n  \n  // Check if initial was sent more than 24h ago\n  if (!initialSentAt) return false;\n  const sentDate = new Date(initialSentAt);\n  if (isNaN(sentDate.getTime())) return false; // Invalid date\n  if (sentDate > twentyFourHoursAgo) return false;\n  \n  // Check if user completed survey - match by EMAIL first (more reliable)\n  const normalizedEmail = email.toLowerCase().trim();\n  if (recentRespondentEmails.has(normalizedEmail)) {\n    console.log(`Skipping ${name} (${email}): Already completed survey (email match)`);\n    return false;\n  }\n  \n  // Also check by name as backup\n  const normalizedName = name.toLowerCase().trim().replace(/\\s+/g, ' ');\n  if (recentRespondentNames.has(normalizedName)) {\n    console.log(`Skipping ${name} (${email}): Already completed survey (name match)`);\n    return false;\n  }\n  \n  return true;\n});\n\nconsole.log(`${needsReminder.length} people need reminder emails`);\n\nif (needsReminder.length === 0) {\n  return [{ json: { email: null, name: 'No Reminders Needed' } }];\n}\n\nreturn needsReminder.map(item => ({\n  json: {\n    email: item.json.Email || item.json.email,\n    name: item.json.Name || item.json.name,\n    eventTitle: item.json['Event Title'] || item.json.eventTitle,\n    eventType: item.json['Event Type'] || item.json.eventType\n  }\n}));"
